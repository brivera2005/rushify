# Path to rushify on the NAS host (for deploy/synology/docker-compose.maze-bot.yml)
REPO_HOST_PATH=/volume1/docker/rushify

# Path to the rushify git repo (inside container: /repo)
REPO_PATH=..

# Where bot state lives (schedule, maze progression). Use a persistent volume on NAS.
STATE_DIR=./data

# Hint output folder inside the repo (relative to REPO_PATH)
HINT_DIR=the-maze

# Daily commit count range (inclusive)
COMMITS_MIN=5
COMMITS_MAX=20

# Git identity for hint commits (no secrets here)
GIT_AUTHOR_NAME=The Maze
GIT_AUTHOR_EMAIL=maze@localhost

# Optional: remote to push after each drop (leave empty to commit locally only)
# GIT_REMOTE=origin
# GIT_BRANCH=main

# Timezone for scheduling (Synology: America/New_York, etc.)
TZ=UTC

# Daemon tick interval in ms (default 60000 = 1 minute)
TICK_MS=60000

# Set to 1 to skip git push even when GIT_REMOTE is set
DRY_RUN=0
