# Rushify — Server-side configuration (never expose to the browser)

# Media server (Jellyfin backend — accessed only via Rushify API routes)
JELLYFIN_SERVER_URL=http://localhost:8096
JELLYFIN_API_KEY=your_api_key_here

# IPTV sources (fetched and parsed server-side only)
IPTV_M3U_URL=https://example.com/playlist.m3u
IPTV_EPG_URL=https://example.com/epg.xml

# IPTV cache tuning (optional — defaults shown)
IPTV_CACHE_TTL_SECONDS=300
IPTV_STALE_TTL_SECONDS=900
IPTV_REFRESH_INTERVAL_SECONDS=600

# Node environment
NODE_ENV=production
