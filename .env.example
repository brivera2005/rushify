# Rushify — Server-side configuration (never expose to the browser)
#
# Copy to .env.local for development, or .env for Docker / unRAID.
# After editing, restart Rushify (npm run dev or docker compose restart).

# ── Rushify users (multi-user auth) ───────────────────────────────────────────
# JSON array — server-side only, never commit real passwords to git.
# RUSHIFY_USERS=[{"username":"admin","password":"admin","role":"admin"},{"username":"benjamin","password":"rushify2024","role":"user"}]

# Legacy single-admin fallback (used if RUSHIFY_USERS is empty):
RUSHIFY_ADMIN_USERNAME=admin
RUSHIFY_ADMIN_PASSWORD=admin

# ── Ports & TLS ───────────────────────────────────────────────────────────────
# Production: Caddy on PUBLIC_PORT (8096), Jellyfin on 8097
PUBLIC_PORT=8096
RUSHIFY_TLS=false
SESSION_COOKIE_SECURE=false

# Optional PIN gate before login (recommended when port-forwarding):
# RUSHIFY_ACCESS_PIN=

# Public URL clients use for remote access (falls back to NEXT_PUBLIC_APP_URL):
RUSHIFY_PUBLIC_URL=http://192.168.0.19:8096

# Live stream timeouts (ms)
IPTV_MAX_SEGMENT_WAIT_MS=8000
IPTV_CONNECT_TIMEOUT_MS=5000
IPTV_DIRECT_SEGMENTS=false

# ── Media engine (library + Live TV) ───────────────────────────────────────────
# After port migration, API is on 8097 (Rushify owns 8096):
JELLYFIN_SERVER_URL=http://192.168.0.19:8097

# API key from Dashboard → Advanced → API Keys in your media engine admin UI
# JELLYFIN_API_KEY=

# Live TV backend: direct (Xtream playback), jellyfin (engine live TV), or auto
IPTV_BACKEND=direct

# ── Live TV provider (for media engine tuner setup + direct fallback) ─────────
# Configure tuner + EPG in the media engine admin UI. These vars are server-only.
IPTV_XTREAM_URL=http://your-provider:port
IPTV_XTREAM_USERNAME=
IPTV_XTREAM_PASSWORD=

# Raw playlist fallback (optional)
IPTV_M3U_URL=
IPTV_EPG_URL=

# IPTV cache tuning (optional — defaults shown)
IPTV_CACHE_TTL_SECONDS=300
IPTV_STALE_TTL_SECONDS=900
IPTV_EPG_CACHE_TTL_SECONDS=600
IPTV_EPG_STALE_TTL_SECONDS=3600
IPTV_REFRESH_INTERVAL_SECONDS=600
# Server default — English channels only (non-English never returned when true)
IPTV_ENGLISH_ONLY=true
# Stricter than English-only — only US| / USA| region categories (takes precedence)
IPTV_US_ONLY=true

# Node environment
NODE_ENV=production

# Public URL for Chromecast stream URLs (must match what your TV/Chromecast can reach)
NEXT_PUBLIC_APP_URL=http://192.168.0.19:8096

# Google Cast receiver app ID (Default Media Receiver)
NEXT_PUBLIC_GOOGLE_CAST_APP_ID=CC1AD845

# Docker host port (legacy dev — production uses Caddy on PUBLIC_PORT 8096)
PORT=3000
