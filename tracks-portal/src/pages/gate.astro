---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout title="Enter PIN · RushTracks" description="Enter the PIN shown on your TV to browse Tracks.">
  <main class="mx-auto max-w-md px-6 py-16 md:py-24 min-h-screen flex flex-col justify-center">
    <SiteHeader compact>
      <h1 class="font-display text-3xl md:text-4xl font-bold leading-tight mt-4">Enter PIN</h1>
      <p class="text-white/60 mt-2 text-sm leading-relaxed">
        Open Tracks on your TV, tap the QR icon, then type the 6-digit PIN shown on screen.
      </p>
    </SiteHeader>

    <form id="pin-form" class="space-y-4 mt-6">
      <label class="block">
        <span class="text-[10px] uppercase tracking-[0.3em] text-white/45">6-digit PIN</span>
        <input
          id="pin-input"
          name="pin"
          type="text"
          inputmode="numeric"
          pattern="[0-9]{6}"
          maxlength="6"
          autocomplete="one-time-code"
          required
          class="mt-2 w-full bg-obsidian border border-white/20 px-4 py-3 text-2xl tracking-[0.35em] text-center font-display text-white focus:border-copper focus:outline-none focus:ring-1 focus:ring-copper/30 transition-colors duration-200"
          placeholder="000000"
        />
      </label>
      <p id="pin-error" class="text-copper text-sm hidden" role="alert"></p>
      <button
        type="submit"
        class="w-full border border-copper bg-copper text-black font-semibold uppercase tracking-[0.18em] py-3 text-sm hover:bg-transparent hover:text-copper transition-colors duration-200"
      >
        Continue
      </button>
    </form>

    <p class="text-white/35 text-[11px] mt-8 leading-relaxed">
      PINs refresh each time you open the QR screen on TV. Scanning the QR takes you here; enter the current PIN to continue.
    </p>
  </main>

  <script>
    const form = document.getElementById('pin-form') as HTMLFormElement;
    const input = document.getElementById('pin-input') as HTMLInputElement;
    const errorEl = document.getElementById('pin-error') as HTMLParagraphElement;
    const params = new URLSearchParams(window.location.search);
    const next = params.get('next') || '/';

    input.addEventListener('input', () => {
      input.value = input.value.replace(/\D/g, '').slice(0, 6);
      errorEl.classList.add('hidden');
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const pin = input.value.trim();
      if (!/^\d{6}$/.test(pin)) {
        errorEl.textContent = 'Enter the 6-digit PIN from your TV.';
        errorEl.classList.remove('hidden');
        return;
      }
      errorEl.classList.add('hidden');
      try {
        const res = await fetch('/api/pin', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ pin }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          errorEl.textContent = data.error || 'PIN expired or incorrect. Open QR on your TV again.';
          errorEl.classList.remove('hidden');
          return;
        }
        window.location.href = data.redirect || next;
      } catch {
        errorEl.textContent = 'Network error. Try again.';
        errorEl.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>
