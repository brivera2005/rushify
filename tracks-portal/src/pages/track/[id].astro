---
import enrichedTracks from '../../data/tracks-enriched.json';
import allTracks from '../../data/tracks.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackItemCard from '../../components/TrackItemCard.astro';
import RelatedTracks from '../../components/RelatedTracks.astro';
import type { EnrichedTrack } from '../../lib/types';

const tracks = enrichedTracks as EnrichedTrack[];
const trackList = allTracks as EnrichedTrack[];

export function getStaticPaths() {
  return (enrichedTracks as EnrichedTrack[]).map((track) => ({ params: { id: track.id }, props: { track } }));
}

const { track } = Astro.props;
const coreItems = track.sequence;
const supplementalItems = track.supplemental ?? [];
const coreCount = coreItems.length;

const KOBO_CLARA_URL = 'https://www.amazon.com/dp/B0CZXYV8GT?tag=tomewizard-20';
const TOMEWIZARD_URL = 'https://www.tomewizard.com';
---

<BaseLayout title={`${track.title} · RushTracks`} description={track.description}>
  <main class="mx-auto max-w-3xl px-4 sm:px-6 py-10 md:py-16">
    <a href="/" class="text-white/50 text-sm uppercase tracking-widest hover:text-copper transition-colors">← All Tracks</a>

    <header class="mt-6 mb-10 border-b border-white/15 pb-8">
      <h1 class="font-display text-3xl md:text-5xl font-bold leading-tight">{track.title}</h1>
      <p class="text-white/70 mt-4 text-base md:text-lg leading-relaxed">{track.description}</p>
      <div class="flex flex-wrap items-center gap-3 mt-5">
        <p class="text-copper text-xs uppercase tracking-widest">
          {coreCount} {coreCount === 1 ? 'stop' : 'stops'}
          {supplementalItems.length > 0 && ` · ${supplementalItems.length} optional`}
        </p>
        {coreCount > 0 && (
          <p id={`track-progress-${track.id}`} class="text-xs uppercase tracking-widest text-emerald-400/80">
            0 of {coreCount} complete
          </p>
        )}
      </div>
      {(track.tags?.length ?? 0) > 0 && (
        <p class="text-[10px] uppercase tracking-wider text-white/35 mt-4">
          Themes: {track.tags!.join(' · ')}
        </p>
      )}
    </header>

    {coreCount > 0 && (
      <section aria-label="Track sequence" class="space-y-4">
        {coreItems.map((item, index) => (
          <TrackItemCard
            item={item}
            stepNumber={index + 1}
            trackId={track.id}
            itemId={item.id}
          />
        ))}
      </section>
    )}

    {supplementalItems.length > 0 && (
      <section aria-label="Supplemental suggestions" class="mt-12 pt-8 border-t border-white/10">
        <header class="mb-5">
          <h2 class="font-display text-xl md:text-2xl text-white/90">If you want more</h2>
          <p class="text-white/45 text-sm mt-1">Optional board games and video games — not required to follow the track.</p>
        </header>
        <div class="space-y-4">
          {supplementalItems.map((item) => (
            <TrackItemCard
              item={item}
              trackId={track.id}
              itemId={item.id}
              supplemental
            />
          ))}
        </div>
      </section>
    )}

    {coreCount === 0 && supplementalItems.length > 0 && (
      <p class="text-white/55 text-sm mb-6">This track is game-focused — everything below is optional fun, not a required order.</p>
    )}

    <RelatedTracks
      currentId={track.id}
      relatedIds={track.relatedTrackIds ?? []}
      allTracks={trackList}
    />

    <footer class="mt-16 pt-8 border-t border-white/10 text-xs text-white/45">
      <p>
        <a href={TOMEWIZARD_URL} target="_blank" rel="noopener noreferrer" class="hover:text-copper transition-colors">TomeWizard.com</a>
        <span class="text-white/20 mx-2" aria-hidden="true">·</span>
        <a href={KOBO_CLARA_URL} target="_blank" rel="noopener noreferrer" class="hover:text-copper transition-colors">Kobo Clara BW</a>
      </p>
    </footer>
  </main>

  <script>
    import { hydrateRushtvButtons } from '../../lib/rushtv-availability-client.ts';
    hydrateRushtvButtons();
  </script>

  {coreCount > 0 && (
    <script define:vars={{ trackId: track.id, coreItemIds: coreItems.map((i) => i.id).filter(Boolean), coreCount }}>
      const storageKey = `rushtracks-progress-${trackId}`;
      const progressEl = document.getElementById(`track-progress-${trackId}`);

      function loadState() {
        try {
          const raw = JSON.parse(localStorage.getItem(storageKey) || '{}');
          if (raw.completedItems) return raw;
          if (raw.completedNodes) {
            return { completedItems: raw.completedNodes, lastVisited: raw.lastVisited };
          }
          return { completedItems: [] };
        } catch {
          return { completedItems: [] };
        }
      }

      function updateHeader(state) {
        if (!progressEl) return;
        const completed = new Set(state.completedItems || []);
        const done = coreItemIds.filter((id) => completed.has(id)).length;
        const pct = coreCount ? Math.round((done / coreCount) * 100) : 0;
        progressEl.textContent = `${done} of ${coreCount} complete · ${pct}%`;
      }

      function syncToggleButtons(state) {
        const completed = new Set(state.completedItems || []);
        document.querySelectorAll('.complete-toggle').forEach((btn) => {
          const id = btn.dataset.itemId;
          const isDone = id && completed.has(id);
          btn.setAttribute('aria-pressed', isDone ? 'true' : 'false');
          btn.classList.toggle('border-emerald-500', Boolean(isDone));
          btn.classList.toggle('text-emerald-400', Boolean(isDone));
        });
      }

      function toggleComplete(itemId) {
        const state = loadState();
        if (!state.completedItems) state.completedItems = [];
        const idx = state.completedItems.indexOf(itemId);
        if (idx >= 0) {
          state.completedItems.splice(idx, 1);
        } else {
          state.completedItems.push(itemId);
        }
        state.lastVisited = new Date().toISOString();
        localStorage.setItem(storageKey, JSON.stringify(state));
        window.dispatchEvent(new CustomEvent('rushtracks-progress', { detail: { trackId, state } }));
        updateHeader(state);
        syncToggleButtons(state);
      }

      document.querySelectorAll('.complete-toggle').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const itemId = btn.dataset.itemId;
          if (itemId) toggleComplete(itemId);
        });
      });

      const initial = loadState();
      updateHeader(initial);
      syncToggleButtons(initial);
      window.addEventListener('rushtracks-progress', (e) => {
        if (e.detail?.trackId === trackId) {
          updateHeader(e.detail.state);
          syncToggleButtons(e.detail.state);
        }
      });
    </script>
  )}
</BaseLayout>
