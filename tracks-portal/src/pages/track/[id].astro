---
import enrichedTracks from '../../data/tracks-enriched.json';
import allTracks from '../../data/tracks.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackItemCard from '../../components/TrackItemCard.astro';
import PathMap from '../../components/PathMap.astro';
import RelatedTracks from '../../components/RelatedTracks.astro';
import type { EnrichedTrack } from '../../lib/types';

const tracks = enrichedTracks as EnrichedTrack[];
const trackList = allTracks as EnrichedTrack[];

export function getStaticPaths() {
  return (enrichedTracks as EnrichedTrack[]).map((track) => ({ params: { id: track.id }, props: { track } }));
}

const { track } = Astro.props;
const coreCount = track.sequence.filter(
  (i) => i.type !== 'crossroads' && i.required !== false && i.type !== 'videogame' && i.type !== 'boardgame',
).length;
const optionalCount = track.sequence.filter((i) => i.required === false).length;

const nodeIdByItemId: Record<string, string> = {};
if (track.map) {
  for (const node of track.map.nodes) {
    nodeIdByItemId[node.itemId] = node.id;
  }
}

const coreNodeIds = track.map
  ? track.map.nodes
      .filter((n) => {
        const item = track.sequence.find((s) => s.id === n.itemId);
        return item && item.type !== 'crossroads' && item.required !== false && item.type !== 'videogame' && item.type !== 'boardgame';
      })
      .map((n) => n.id)
  : track.sequence
      .filter((i) => i.type !== 'crossroads' && i.required !== false && i.type !== 'videogame' && i.type !== 'boardgame')
      .map((i) => i.id!)
      .filter(Boolean);

const KOBO_CLARA_URL = 'https://www.amazon.com/dp/B0CZXYV8GT?tag=tomewizard-20';
const TOMEWIZARD_URL = 'https://www.tomewizard.com';
---

<BaseLayout title={`${track.title} · RushTracks`} description={track.description}>
  <main class="mx-auto max-w-3xl px-4 sm:px-6 py-10 md:py-16">
    <a href="/" class="text-white/50 text-sm uppercase tracking-widest hover:text-copper transition-colors">← All Tracks</a>

    <header class="mt-6 mb-10 border-b border-white/15 pb-8">
      <h1 class="font-display text-3xl md:text-5xl font-bold leading-tight">{track.title}</h1>
      <p class="text-white/70 mt-4 text-base md:text-lg leading-relaxed">{track.description}</p>
      <div class="flex flex-wrap items-center gap-3 mt-5">
        <p class="text-copper text-xs uppercase tracking-widest">
          {coreCount} core stops{optionalCount ? ` · ${optionalCount} optional tier 2` : ''}
        </p>
        <p id={`track-progress-${track.id}`} class="text-xs uppercase tracking-widest text-emerald-400/80">
          0 of {coreCount} core complete
        </p>
        {track.map && (
          <span class="text-[10px] uppercase tracking-wider text-white/45 border border-white/15 px-2 py-0.5">
            Branching path
          </span>
        )}
      </div>
      {(track.tags?.length ?? 0) > 0 && (
        <p class="text-[10px] uppercase tracking-wider text-white/35 mt-4">
          Themes: {track.tags!.join(' · ')}
        </p>
      )}
    </header>

    {track.map && (
      <PathMap trackId={track.id} map={track.map} sequence={track.sequence} />
    )}

    <section aria-label="Track sequence" class="space-y-4">
      {track.sequence.map((item, index) => (
        <TrackItemCard
          item={item}
          index={index}
          trackId={track.id}
          nodeId={item.id ? (nodeIdByItemId[item.id] || item.id) : undefined}
        />
      ))}
    </section>

    <RelatedTracks
      currentId={track.id}
      relatedIds={track.relatedTrackIds ?? []}
      allTracks={trackList}
    />

    <footer class="mt-16 pt-8 border-t border-white/10 text-xs text-white/45">
      <p>
        <a href={TOMEWIZARD_URL} target="_blank" rel="noopener noreferrer" class="hover:text-copper transition-colors">TomeWizard.com</a>
        <span class="text-white/20 mx-2" aria-hidden="true">·</span>
        <a href={KOBO_CLARA_URL} target="_blank" rel="noopener noreferrer" class="hover:text-copper transition-colors">Kobo Clara BW</a>
      </p>
    </footer>
  </main>

  <script define:vars={{ trackId: track.id, coreNodeIds, coreCount }}>
    const storageKey = `rushtracks-progress-${trackId}`;
    const progressEl = document.getElementById(`track-progress-${trackId}`);

    function loadState() {
      try {
        return JSON.parse(localStorage.getItem(storageKey) || '{}');
      } catch {
        return {};
      }
    }

    function updateHeader(state) {
      if (!progressEl) return;
      const completed = new Set(state.completedNodes || []);
      const done = coreNodeIds.filter((id) => completed.has(id)).length;
      const pct = coreCount ? Math.round((done / coreCount) * 100) : 0;
      progressEl.textContent = `${done} of ${coreCount} core complete · ${pct}%`;
    }

    function toggleComplete(nodeId) {
      const state = loadState();
      if (!state.completedNodes) state.completedNodes = [];
      if (!state.chosenPath) state.chosenPath = [];
      const idx = state.completedNodes.indexOf(nodeId);
      if (idx >= 0) {
        state.completedNodes.splice(idx, 1);
      } else {
        state.completedNodes.push(nodeId);
        if (!state.chosenPath.includes(nodeId)) state.chosenPath.push(nodeId);
      }
      state.lastVisited = new Date().toISOString();
      localStorage.setItem(storageKey, JSON.stringify(state));
      window.dispatchEvent(new CustomEvent('rushtracks-progress', { detail: { trackId, state } }));
      updateHeader(state);
    }

    document.querySelectorAll('.complete-toggle').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const nodeId = btn.dataset.nodeId;
        if (nodeId) toggleComplete(nodeId);
      });
    });

    updateHeader(loadState());
    window.addEventListener('rushtracks-progress', (e) => {
      if (e.detail?.trackId === trackId) updateHeader(e.detail.state);
    });
  </script>
</BaseLayout>
