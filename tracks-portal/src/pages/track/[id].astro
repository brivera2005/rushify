---
import tracks from '../../data/tracks.json';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return tracks.map((track) => ({ params: { id: track.id }, props: { track } }));
}

const { track } = Astro.props;

function typeLabel(type: string) {
  switch (type) {
    case 'book': return 'Book';
    case 'show': return 'Series';
    case 'documentary': return 'Documentary';
    default: return 'Film';
  }
}
---

<BaseLayout title={`${track.title} · Tracks`} description={track.description}>
  <main class="mx-auto max-w-2xl px-6 py-12 md:py-20">
    <a href="/" class="text-white/50 text-sm uppercase tracking-widest hover:text-accent">← All Tracks</a>

    <header class="mt-8 mb-12 border-b border-white/15 pb-10">
      <h1 class="font-display text-4xl md:text-5xl font-bold leading-tight">{track.title}</h1>
      <p class="text-white/70 mt-4 text-lg leading-relaxed">{track.description}</p>
    </header>

    <ol class="relative border-l border-white/20 ml-3">
      {track.sequence.map((item, index) => (
        <li class="mb-10 ml-8 relative">
          <span class="absolute -left-[1.35rem] top-1 flex h-3 w-3 rounded-full bg-accent ring-4 ring-black"></span>
          <p class="text-xs uppercase tracking-[0.25em] text-white/45 mb-1">{typeLabel(item.type)} · {index + 1}</p>
          <h2 class="font-display text-xl md:text-2xl">{item.title}</h2>
          {item.author && <p class="text-white/60 mt-1">{item.author}</p>}
          {item.year && <p class="text-white/45 text-sm mt-1">{item.year}</p>}
          {item.type === 'book' && (
            <a
              href="#"
              class="inline-block mt-4 border border-white/30 px-4 py-2 text-xs uppercase tracking-widest hover:border-accent hover:text-accent transition-colors"
            >
              Download · Coming soon
            </a>
          )}
        </li>
      ))}
    </ol>
  </main>
</BaseLayout>
