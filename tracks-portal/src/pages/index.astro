---
import enrichedTracks from '../data/tracks-enriched.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { buildTrackSearchIndex } from '../lib/track-search';
import type { EnrichedTrack } from '../lib/types';

const tracks = enrichedTracks as EnrichedTrack[];
const searchIndex = buildTrackSearchIndex(tracks);
---

<BaseLayout
  title="Tracks · RushTracks"
  description="Curated paths for the discerning through books, film, and television. Browse on your phone, read on your e-reader, watch on RushTV."
>
  <main class="mx-auto max-w-5xl px-4 sm:px-6 py-8 md:py-12">
    <SiteHeader>
      <h1 class="font-display text-2xl md:text-4xl font-bold leading-tight mt-4 mb-2">
        Curated paths for the discerning through books, film, and television.
      </h1>
      <p class="text-sm text-white/55 max-w-2xl leading-relaxed">
        Work through each track in sequence. Reading and watching in order is how the ideas connect.
      </p>
    </SiteHeader>

    <section aria-labelledby="tracks-heading">
      <div class="sticky top-0 z-10 bg-obsidian/95 backdrop-blur-sm pb-3 pt-0.5 -mx-4 px-4 sm:-mx-6 sm:px-6 border-b border-white/5">
        <label for="track-search" class="sr-only">Search tracks</label>
        <input
          id="track-search"
          type="search"
          inputmode="search"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          placeholder="Search titles, authors, genres, themes…"
          class="search-input"
        />
        <p id="track-count" class="mt-1.5 text-[10px] uppercase tracking-[0.22em] text-white/40">
          {tracks.length} tracks
        </p>
      </div>

      <h2 id="tracks-heading" class="sr-only">All Tracks</h2>
      <ul id="track-list" class="grid gap-2 md:grid-cols-2 mt-3">
        {searchIndex.map((entry) => (
          <li data-track-id={entry.id} data-haystack={entry.haystack}>
            <a
              href={`/track/${entry.id}`}
              class="group card-surface card-interactive block p-4 h-full hover:-translate-y-px"
            >
              <div class="flex items-start justify-between gap-2">
                <h3
                  class="track-title font-display text-base md:text-lg group-hover:text-copper transition-colors duration-200 leading-snug"
                  data-plain={entry.title}
                >
                  {entry.title}
                </h3>
              </div>
              <p
                class="track-desc text-white/55 mt-1.5 text-xs leading-relaxed line-clamp-2"
                data-plain={entry.description}
              >
                {entry.description}
              </p>
              <p class="text-copper text-[10px] uppercase tracking-widest mt-2">{entry.stopCount} stops</p>
            </a>
          </li>
        ))}
      </ul>
      <p id="track-empty" class="hidden py-10 text-center text-white/45 text-sm">
        No tracks match your search. Try fewer words or a different spelling.
      </p>
    </section>

    <SiteFooter class="mt-12" />
  </main>

  <script define:vars={{ trackTotal: tracks.length, searchSynonyms: {
    horror: ['scary', 'creepy', 'spooky', 'frightening', 'terror', 'haunted'],
    scary: ['horror', 'creepy', 'spooky', 'frightening'],
    film: ['movie', 'cinema', 'movies'],
    movie: ['film', 'cinema'],
    dystopia: ['dystopian', 'resistance', 'future', 'totalitarian'],
    dystopian: ['dystopia', 'resistance', 'future'],
    'sci-fi': ['science-fiction', 'scifi', 'sf', 'futuristic'],
    fantasy: ['magic', 'sorcery', 'mythic'],
    philosophy: ['existential', 'ethics', 'ideas'],
    'true-crime': ['murder', 'investigation', 'criminal'],
    kids: ['children', 'family', 'young'],
    teens: ['teen', 'ya', 'young-adult'],
    games: ['gaming', 'videogame', 'boardgame'],
    mystery: ['detective', 'suspense', 'investigation'],
    comedy: ['funny', 'humor', 'satire'],
    war: ['combat', 'military', 'battle'],
    nature: ['wilderness', 'outdoors', 'environment'],
    ai: ['artificial-intelligence', 'robot', 'android'],
    hacking: ['hacker', 'cyber', 'infosec'],
    cooking: ['food', 'chef', 'culinary'],
    survival: ['apocalypse', 'post-apocalyptic', 'wilderness'],
  } }}>
    const input = document.getElementById('track-search');
    const list = document.getElementById('track-list');
    const countEl = document.getElementById('track-count');
    const emptyEl = document.getElementById('track-empty');
    if (!input || !list) throw new Error('track search elements missing');

    const items = Array.from(list.querySelectorAll('li'));

    function normalize(value) {
      return value
        .toLowerCase()
        .normalize('NFD')
        .replace(/\p{M}/gu, '')
        .replace(/[^\p{L}\p{N}\s]/gu, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function parseTerms(raw) {
      return normalize(raw).split(' ').filter(Boolean);
    }

    function stemVariants(term) {
      const variants = new Set([term]);
      if (term.length < 4) return [...variants];
      if (term.endsWith('ies') && term.length > 5) variants.add(term.slice(0, -3) + 'y');
      if (term.endsWith('ing') && term.length > 6) {
        variants.add(term.slice(0, -3));
        variants.add(term.slice(0, -3) + 'e');
      }
      if (term.endsWith('ed') && term.length > 5) {
        variants.add(term.slice(0, -2));
        variants.add(term.slice(0, -1));
      }
      if (term.endsWith('s') && !term.endsWith('ss') && term.length > 4) {
        variants.add(term.slice(0, -1));
      }
      return [...variants].filter((v) => v.length >= 3);
    }

    function expandTerm(term) {
      const expanded = new Set([term]);
      const direct = searchSynonyms[term];
      if (direct) direct.forEach((a) => expanded.add(a));
      for (const [canonical, aliases] of Object.entries(searchSynonyms)) {
        if (aliases.includes(term)) {
          expanded.add(canonical);
          aliases.forEach((a) => expanded.add(a));
        }
      }
      return [...expanded];
    }

    function termMatchesHaystack(haystack, term) {
      const candidates = new Set();
      for (const expanded of expandTerm(term)) {
        for (const stem of stemVariants(expanded)) candidates.add(stem);
      }
      for (const candidate of candidates) {
        if (haystack.includes(candidate)) return true;
      }
      return false;
    }

    function escapeHtml(text) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function highlightPlain(text, terms) {
      if (!terms.length || !text) return escapeHtml(text);
      let html = escapeHtml(text);
      const seen = new Set();
      for (const term of [...terms].sort((a, b) => b.length - a.length)) {
        if (seen.has(term)) continue;
        seen.add(term);
        const re = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
        html = html.replace(re, '<mark class="search-hit bg-copper/25 text-copper rounded-sm px-0.5">$1</mark>');
      }
      return html;
    }

    function applyHighlights(visible) {
      const terms = parseTerms(input.value);
      for (const item of items) {
        if (item.hidden) continue;
        const titleEl = item.querySelector('.track-title');
        const descEl = item.querySelector('.track-desc');
        const plainTitle = titleEl?.dataset.plain ?? '';
        const plainDesc = descEl?.dataset.plain ?? '';
        if (titleEl) {
          titleEl.innerHTML = terms.length ? highlightPlain(plainTitle, terms) : escapeHtml(plainTitle);
        }
        if (descEl) {
          descEl.innerHTML = terms.length ? highlightPlain(plainDesc, terms) : escapeHtml(plainDesc);
        }
      }
    }

    function filterTracks() {
      const terms = parseTerms(input.value);
      let visible = 0;
      for (const item of items) {
        const haystack = item.dataset.haystack ?? '';
        const show = !terms.length || terms.every((term) => termMatchesHaystack(haystack, term));
        item.hidden = !show;
        if (show) visible += 1;
      }
      if (countEl) {
        const q = input.value.trim();
        countEl.textContent = q
          ? `${visible} of ${trackTotal} tracks · "${q}"`
          : `${trackTotal} tracks`;
      }
      if (emptyEl) {
        emptyEl.classList.toggle('hidden', visible > 0);
      }
      list.classList.toggle('hidden', visible === 0);
      applyHighlights(visible);
    }

    let debounceTimer;
    function scheduleFilter() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterTracks, 120);
    }

    input.addEventListener('input', scheduleFilter);
    input.addEventListener('search', filterTracks);
    filterTracks();
  </script>
</BaseLayout>
