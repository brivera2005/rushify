---
import type { Track } from '../lib/types';

interface Props {
  currentId: string;
  relatedIds: string[];
  allTracks: Track[];
}

const { currentId, relatedIds, allTracks } = Astro.props;
const related = relatedIds
  .map((id) => allTracks.find((t) => t.id === id))
  .filter(Boolean) as Track[];

if (related.length === 0) return null;
---

<section class="mt-12 pt-6 border-t border-white/10" aria-label="Related tracks">
  <h2 class="font-display text-base text-white/75 mb-3">Related Tracks</h2>
  <ul class="grid gap-2 sm:grid-cols-2">
    {related.map((track) => (
      <li>
        <a
          href={`/track/${track.id}`}
          class:list={[
            'card-surface card-interactive block p-3 transition-colors duration-200',
            track.id === currentId ? 'border-copper text-copper' : 'hover:-translate-y-px',
          ]}
        >
          <h3 class="font-display text-sm md:text-base leading-snug">{track.title}</h3>
          <p class="text-white/45 text-xs mt-1 line-clamp-2">{track.description}</p>
          {(track.tags ?? []).includes('v2') && (
            <span class="inline-block mt-1.5 text-[8px] uppercase tracking-wider text-copper border border-copper/35 px-1.5 py-px">
              Deep dive
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>
