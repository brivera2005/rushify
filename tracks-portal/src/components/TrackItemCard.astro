---
import type { EnrichedSequenceItem } from '../lib/types';
import { typeLabel } from '../lib/track-items';
import { bookTitleInitial, isOpenLibraryCover, openLibraryCoverSize } from '../lib/book-covers';
import { buildRushTvDetailUrl, isRushTvEligibleItemType, tmdbAvailabilityKey } from '../lib/rushtv-deeplink';

interface Props {
  item: EnrichedSequenceItem;
  trackId: string;
  itemId?: string;
  stepNumber?: number;
  supplemental?: boolean;
}

const { item, trackId, itemId, stepNumber, supplemental = false } = Astro.props;

const meta = item.metadata;
const isBook = item.type === 'book';
const bookCoverUrl = isBook && meta?.coverUrl && isOpenLibraryCover(meta.coverUrl)
  ? openLibraryCoverSize(meta.coverUrl, 'S')
  : isBook
    ? meta?.coverUrl
    : undefined;
const imageUrl = isBook ? bookCoverUrl : meta?.posterUrl;
const showBookPlaceholder = isBook && !imageUrl;
const titleInitial = bookTitleInitial(item.title);
const itemDomId = itemId || item.id || `${trackId}-item`;
const rushTvEligible =
  meta?.tmdbId && meta?.mediaType && isRushTvEligibleItemType(item.type);
const rushTvKey = rushTvEligible
  ? tmdbAvailabilityKey(meta!.mediaType!, meta!.tmdbId!)
  : null;
const rushTvUrl = rushTvEligible
  ? buildRushTvDetailUrl(meta!.tmdbId!, meta!.mediaType!)
  : null;
const displayYear = meta?.year || item.year;
const hasDesktopDetails =
  (meta?.genres && meta.genres.length > 0) ||
  meta?.rating != null ||
  meta?.overview;
const hasMobileExtras =
  item.note ||
  (isBook && meta?.amazonUrl) ||
  (isBook && meta?.coverUrl && meta?.openLibraryUrl);
const showDesktopPanel =
  hasDesktopDetails ||
  (item.type === 'book' && meta?.amazonUrl) ||
  (isBook && meta?.coverUrl && meta?.openLibraryUrl);
---

<article
  id={`card-${itemDomId}`}
  class:list={[
    'track-item-card border border-white/15 bg-white/[0.02] overflow-hidden transition-all duration-300',
    supplemental && 'track-item-card--supplemental border-dashed border-copper/25',
  ]}
  data-item-id={itemDomId}
  data-type={item.type}
>
  <div class="track-item-row">
    <div class="track-item-thumb relative shrink-0 overflow-hidden bg-white/5">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          width="64"
          height="96"
        />
      ) : showBookPlaceholder ? (
        <div
          class="absolute inset-0 flex flex-col items-center justify-center gap-0.5 bg-gradient-to-b from-white/[0.04] to-white/[0.01]"
          aria-hidden="true"
        >
          <svg class="h-4 w-4 text-copper/40 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          <span class="font-display text-sm leading-none text-copper/55 sm:text-base">{titleInitial}</span>
        </div>
      ) : (
        <div class="absolute inset-0 flex items-center justify-center p-1 text-center text-[8px] uppercase tracking-wider text-white/20">
          {typeLabel(item.type)}
        </div>
      )}
      {supplemental && (
        <span class="absolute left-0 top-0 border border-copper/50 bg-black/80 px-1 py-px text-[7px] uppercase tracking-wider text-copper">
          Opt
        </span>
      )}
    </div>

    <div class="track-item-body min-w-0 flex-1">
      <div class="flex items-start gap-1.5 sm:gap-2">
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5">
            <span class="track-item-badge">{typeLabel(item.type)}</span>
            {stepNumber != null && (
              <span class="text-[10px] uppercase tracking-wider text-white/35">Stop {stepNumber}</span>
            )}
          </div>
          <h2 class="track-item-title font-display leading-tight">{item.title}</h2>
          {(item.author || displayYear) && (
            <p class="track-item-meta truncate">
              {[item.author, displayYear].filter(Boolean).join(' · ')}
            </p>
          )}
        </div>

        <div class="track-item-actions shrink-0 flex items-center gap-1">
          {!supplemental && itemId && (
            <button
              type="button"
              class="complete-toggle flex h-7 w-7 items-center justify-center border border-white/25 transition-colors hover:border-emerald-500 sm:h-8 sm:w-8"
              data-item-id={itemId}
              aria-pressed="false"
              aria-label="Mark complete"
              title="Mark complete"
            >
              <span class="complete-icon text-xs sm:text-sm" aria-hidden="true">✓</span>
            </button>
          )}
          {rushTvEligible && rushTvUrl && rushTvKey && (
            <a
              href={rushTvUrl}
              class="rushtv-cta rushtv-cta--compact rushtv-cta--loading"
              data-tmdb-key={rushTvKey}
              data-tmdb-id={meta!.tmdbId}
              data-media-type={meta!.mediaType}
              aria-label="Checking RushTV availability"
            >
              <span class="rushtv-cta-spinner" aria-hidden="true"></span>
              <span class="rushtv-cta-label">Checking…</span>
            </a>
          )}
        </div>
      </div>

      {hasMobileExtras && (
        <div class="track-item-extras md:hidden">
          {item.note && <p class="track-item-note italic">{item.note}</p>}
          <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
            {item.type === 'book' && meta?.amazonUrl && (
              <a
                href={meta.amazonUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="track-item-link"
              >
                Amazon
              </a>
            )}
            {isBook && meta?.coverUrl && meta?.openLibraryUrl && (
              <a
                href={meta.openLibraryUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="track-item-courtesy"
              >
                Cover from Open Library
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  </div>

  {showDesktopPanel && (
    <div class="track-item-details hidden md:block">
      {meta?.genres && meta.genres.length > 0 && (
        <p class="text-sm text-white/50">{meta.genres.slice(0, 4).join(' · ')}</p>
      )}
      {meta?.rating != null && (
        <p class="mt-1 text-sm font-medium text-copper">
          ★ {meta.rating}/10
          {meta.ratingCount ? (
            <span class="font-normal text-white/40"> · {meta.ratingCount.toLocaleString()} votes</span>
          ) : null}
        </p>
      )}
      {meta?.overview && (
        <p class="mt-2 text-sm leading-relaxed text-white/55 line-clamp-3">{meta.overview}</p>
      )}
      {item.type === 'book' && meta?.amazonUrl && (
        <a
          href={meta.amazonUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-block border border-copper/60 px-4 py-2 text-xs uppercase tracking-widest text-copper transition-colors hover:bg-copper hover:text-black"
        >
          Buy on Amazon
        </a>
      )}
      {isBook && meta?.coverUrl && meta?.openLibraryUrl && (
        <p class="mt-2 text-[10px] text-white/30">
          <a
            href={meta.openLibraryUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-copper/70"
          >
            Cover from Open Library
          </a>
        </p>
      )}
    </div>
  )}
</article>
