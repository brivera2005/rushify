---
import type { EnrichedSequenceItem, TrackMap } from '../lib/types';
import {
  buildJourneyLayers,
  countCoreSteps,
  isOptionalItem,
  itemImage,
  typeIcon,
  typeLabel,
} from '../lib/path-progress';

interface Props {
  trackId: string;
  map: TrackMap;
  sequence: EnrichedSequenceItem[];
}

const { trackId, map, sequence } = Astro.props;

const itemById = Object.fromEntries(
  sequence.filter((s) => s.id).map((s) => [s.id!, s]),
);

const layers = buildJourneyLayers(map, sequence);
const coreStepCount = countCoreSteps(layers, sequence);

const layerPayload = layers.map((layer) => ({
  layer: layer.layer,
  kind: layer.kind,
  choiceItemId: layer.choiceItemId,
  nodes:
    layer.kind === 'choice'
      ? (layer.choiceOptions || []).map((opt) => ({
          nodeId: opt.nodeId,
          itemId: opt.itemId,
          title: opt.item?.title || itemById[opt.itemId]?.title || 'Untitled',
          type: opt.item?.type || itemById[opt.itemId]?.type || 'movie',
          optional: isOptionalItem(opt.item || itemById[opt.itemId]),
        }))
      : layer.nodes.map((node) => {
          const item = itemById[node.itemId];
          return {
            nodeId: node.id,
            itemId: node.itemId,
            title: item?.title || 'Untitled',
            type: item?.type || 'movie',
            optional: isOptionalItem(item),
          };
        }),
}));
---

<section class="journey-map" aria-label="Your journey map" id={`journey-map-${trackId}`}>
  <div class="journey-toolbar">
    <div>
      <h2 class="font-display text-base text-white/80 mb-1">Your Journey</h2>
      <p id={`journey-status-${trackId}`} class="journey-status">
        Step 1 of {coreStepCount} · Start below
      </p>
    </div>
    <button type="button" id={`journey-reset-${trackId}`} class="journey-reset">
      Start over
    </button>
  </div>

  <ol class="journey-timeline">
    <li class="journey-layer journey-layer--start" data-layer="-1">
      <div class="journey-start-badge">Start</div>
    </li>

    {
      layers.map((layer) => {
        const isOptionalLayer =
          layer.kind === 'choice' &&
          (layer.choiceOptions || []).every((o) => isOptionalItem(o.item || itemById[o.itemId]));
        const layerHasOptionalOnly =
          layer.kind === 'steps' &&
          layer.nodes.every((n) => isOptionalItem(itemById[n.itemId]));

        return (
          <li
            class:list={[
              'journey-layer',
              (isOptionalLayer || layerHasOptionalOnly) && 'journey-layer--optional',
            ]}
            data-layer={layer.layer}
            data-optional={(isOptionalLayer || layerHasOptionalOnly) ? 'true' : 'false'}
          >
            {layer.kind === 'choice' ? (
              <div
                class="journey-choice-panel"
                data-choice-layer={layer.layer}
                {...(layer.choiceItemId ? { 'data-crossroads-item': layer.choiceItemId } : {})}
              >
                <h3 class="journey-choice-heading">{layer.choiceLabel || 'Pick one path'}</h3>
                <p class="journey-choice-hint">
                  Choose one to continue — siblings fade as skipped. Optional side quests are dashed.
                </p>
                <div class="journey-choice-grid">
                  {(layer.choiceOptions || []).map((opt) => {
                    const item = opt.item || itemById[opt.itemId];
                    const optional = isOptionalItem(item);
                    const thumb = itemImage(item);
                    return (
                      <button
                        type="button"
                        class:list={[
                          'journey-node-card',
                          optional && 'journey-node-card--optional',
                        ]}
                        data-node-id={opt.nodeId}
                        data-item-id={opt.itemId}
                        data-layer={layer.layer}
                        data-optional={optional ? 'true' : 'false'}
                        data-is-choice="true"
                      >
                        <div class="journey-node-body">
                          {thumb ? (
                            <img src={thumb} alt="" class="journey-node-thumb" loading="lazy" width="48" height="64" />
                          ) : (
                            <div class="journey-node-thumb flex items-center justify-center text-lg" aria-hidden="true">
                              {typeIcon(item?.type || 'movie')}
                            </div>
                          )}
                          <div class="journey-node-meta">
                            <p class="journey-node-type">
                              {typeIcon(item?.type || 'movie')} {typeLabel(item?.type || 'movie')}
                              {optional && (
                                <span class="journey-node-badge journey-node-badge--optional ml-2">
                                  Optional
                                </span>
                              )}
                            </p>
                            <p class="journey-node-title">{item?.title || 'Untitled'}</p>
                            {item?.note && <p class="text-[11px] text-white/45 mt-1 line-clamp-2">{item.note}</p>}
                          </div>
                          <span class="journey-node-badge" aria-live="polite"></span>
                        </div>
                      </button>
                    );
                  })}
                </div>
              </div>
            ) : (
              layer.nodes.map((node) => {
                const item = itemById[node.itemId];
                if (item?.type === 'crossroads') return null;
                const optional = isOptionalItem(item);
                const thumb = itemImage(item);
                return (
                  <button
                    type="button"
                    class:list={[
                      'journey-node-card mb-3',
                      optional && 'journey-node-card--optional',
                    ]}
                    data-node-id={node.id}
                    data-item-id={node.itemId}
                    data-layer={layer.layer}
                    data-optional={optional ? 'true' : 'false'}
                    data-is-choice="false"
                  >
                    <div class="journey-node-body">
                      {thumb ? (
                        <img src={thumb} alt="" class="journey-node-thumb" loading="lazy" width="48" height="64" />
                      ) : (
                        <div class="journey-node-thumb flex items-center justify-center text-lg" aria-hidden="true">
                          {typeIcon(item?.type || 'movie')}
                        </div>
                      )}
                      <div class="journey-node-meta">
                        <p class="journey-node-type">
                          {typeIcon(item?.type || 'movie')} {typeLabel(item?.type || 'movie')}
                          {optional && (
                            <span class="journey-node-badge journey-node-badge--optional ml-2">Side quest</span>
                          )}
                        </p>
                        <p class="journey-node-title">{item?.title || 'Untitled'}</p>
                        {item?.note && <p class="text-[11px] text-white/45 mt-1 line-clamp-2">{item.note}</p>}
                      </div>
                      <span class="journey-node-badge" aria-live="polite"></span>
                    </div>
                  </button>
                );
              })
            )}
          </li>
        );
      })
    }
  </ol>
</section>

<script define:vars={{ trackId, layerPayload, coreStepCount, mapJson: JSON.stringify(map) }}>
  import { initJourneyMap } from '../../lib/journey-map-client.ts';
  initJourneyMap({
    trackId,
    layers: layerPayload,
    coreStepCount,
    mapJson,
  });
</script>
