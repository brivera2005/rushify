# Stripe (required)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Optional: publishable key if you add Stripe Elements later
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL (must match deployed domain for Checkout redirects + webhooks)
PUBLIC_APP_URL=https://rushtv-billing.pages.dev

# Statement descriptor shown on card statements (also set in Stripe Dashboard)
STRIPE_STATEMENT_DESCRIPTOR=RUSH* FAMILY MEDIA

# Bearer token for GET /api/subscriber/status (TV app / internal checks)
SUBSCRIBER_API_SECRET=change-me-to-a-long-random-string

# Comma-separated lifetime access emails (host/family — never billed)
FREE_SUBSCRIBER_EMAILS=host@example.com,family@example.com
