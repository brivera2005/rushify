---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    title: 'Live TV',
    description: 'Family-friendly live channels with a polished guide experience on TV and mobile.',
    icon: '▶',
  },
  {
    title: 'Movies & Shows',
    description: 'On-demand movies and series from your private family media library.',
    icon: '◎',
  },
  {
    title: 'Requests',
    description: 'Ask for new titles and keep the library growing without the hassle.',
    icon: '✦',
  },
  {
    title: 'Tracks Portal',
    description: 'Browse curated recommendations and discover what to watch next.',
    icon: '◈',
  },
];
---

<BaseLayout
  title="RushTV Family Access"
  description="Private family media portal with live TV, on-demand movies and shows, requests, and the Tracks companion portal."
>
  <header class="mx-auto flex max-w-5xl items-center justify-between px-5 py-6 sm:px-8">
    <div class="flex items-center gap-3">
      <img src="/rushtv-logo.png" alt="RushTV" class="h-10 w-10 rounded-lg" width="40" height="40" />
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-muted">RushTV</p>
        <p class="text-lg font-semibold brand-gradient">Family Access</p>
      </div>
    </div>
    <a href="#subscribe" class="hidden text-sm text-muted hover:text-white sm:inline">Subscribe</a>
  </header>

  <main class="mx-auto max-w-5xl px-5 pb-16 sm:px-8">
    <section class="py-10 sm:py-16">
      <div class="max-w-3xl">
        <p class="mb-4 text-xs uppercase tracking-[0.35em] text-accent-secondary">Private family media</p>
        <h1 class="text-4xl font-bold leading-tight sm:text-5xl">
          Your family media portal,<br />
          <span class="brand-gradient">one simple subscription.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
          RushTV Family Access brings together live TV, on-demand movies and shows, title requests,
          and the Tracks discovery portal — hosted for friends and family, without the complexity.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="#subscribe" class="btn-primary">Start 7-day free trial</a>
          <p class="text-sm text-muted">Then $39.99/month · cancel anytime</p>
        </div>
      </div>
    </section>

    <section class="grid gap-4 sm:grid-cols-2">
      {features.map((feature) => (
        <article class="card-surface rounded-2xl p-5 sm:p-6">
          <div class="flex items-start gap-4">
            <div class="feature-icon">{feature.icon}</div>
            <div>
              <h2 class="text-lg font-semibold">{feature.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-muted">{feature.description}</p>
            </div>
          </div>
        </article>
      ))}
    </section>

    <section id="subscribe" class="mt-14 scroll-mt-8">
      <div class="card-surface rounded-3xl border-accent/20 p-6 shadow-glow sm:p-8">
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div>
            <p class="text-xs uppercase tracking-[0.35em] text-accent">Subscribe</p>
            <h2 class="mt-3 text-3xl font-bold">RushTV Family Access</h2>
            <ul class="mt-5 space-y-3 text-sm text-muted">
              <li>✓ 7-day free trial — card required, cancel before day 7 to avoid charge</li>
              <li>✓ $39.99/month after trial, billed monthly</li>
              <li>✓ Live TV, VOD, requests, and Tracks portal included</li>
              <li>✓ Secure checkout powered by Stripe</li>
            </ul>
          </div>

          <form id="checkout-form" class="rounded-2xl border border-white/10 bg-elevated/80 p-5 sm:p-6">
            <label for="email" class="block text-sm font-medium text-white/90">Email for your account</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              required
              class="mt-2 w-full rounded-xl border border-white/10 bg-surface px-4 py-3 text-white outline-none transition focus:border-accent/60 focus:ring-1 focus:ring-accent/30"
            />
            <p id="checkout-error" class="mt-3 hidden text-sm text-red-400"></p>
            <button id="checkout-button" type="submit" class="btn-primary mt-5 w-full">
              Continue to secure checkout
            </button>
            <p class="mt-4 text-center text-xs leading-relaxed text-muted">
              Card statement may show <span class="text-white/70">RUSH* FAMILY MEDIA</span>.
              By subscribing you agree to month-to-month billing after the trial.
            </p>
          </form>
        </div>
      </div>
    </section>

    <section class="mt-10 text-center text-xs text-muted">
      <p>Questions? Reply to your invite email or contact your RushTV host.</p>
      <p class="mt-2">RushTV Family Access is a private friends-and-family service.</p>
    </section>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById('checkout-form') as HTMLFormElement | null;
  const button = document.getElementById('checkout-button') as HTMLButtonElement | null;
  const errorEl = document.getElementById('checkout-error') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!button || !errorEl) return;

    const emailInput = form.querySelector('#email') as HTMLInputElement;
    const email = emailInput.value.trim();

    button.disabled = true;
    button.textContent = 'Redirecting…';
    errorEl.classList.add('hidden');

    try {
      const response = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = (await response.json()) as { url?: string; error?: string };
      if (!response.ok || !data.url) {
        throw new Error(data.error ?? 'Unable to start checkout.');
      }

      window.location.href = data.url;
    } catch (error) {
      errorEl.textContent = error instanceof Error ? error.message : 'Unable to start checkout.';
      errorEl.classList.remove('hidden');
      button.disabled = false;
      button.textContent = 'Continue to secure checkout';
    }
  });
</script>
