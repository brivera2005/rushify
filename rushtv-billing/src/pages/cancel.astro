---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Checkout canceled · RushTV Family Access">
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col items-center justify-center px-5 py-16 text-center">
    <div class="card-surface rounded-3xl p-8 sm:p-10">
      <h1 class="text-3xl font-bold">Checkout canceled</h1>
      <p class="mt-4 text-muted">
        No worries — you weren't charged. You can return anytime to start your 7-day free trial.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a href="/#subscribe" class="btn-primary">Try again</a>
        <a href="/" class="btn-secondary">Back to home</a>
      </div>
    </div>
  </main>
</BaseLayout>
